# Backend
BACKEND_HOST_PORT=42002

# Nanobot / LLM
LLM_API_KEY=
LLM_API_MODEL=qwen-plus
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NANOBOT_ACCESS_KEY=change-me-to-a-random-string

# Docker image registries (leave empty for Docker Hub defaults)
REGISTRY_PREFIX_DOCKER_HUB=
REGISTRY_PREFIX_GHCR=ghcr.io/inno-se-toolkit/

# Host UID/GID (for file permissions in Docker)
HOST_UID=1000
HOST_GID=1000

# Gateway / Caddy
GATEWAY_HOST_PORT=8080

# Nanobot webchat
NANOBOT_WEBCHAT_CONTAINER_PORT=8765
